{
  "name": "alugafacil-pro",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "set NODE_OPTIONS=--max-old-space-size=4096 && npm run dev --workspaces --if-present",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "db:migrate": "npm run db:migrate --workspace=server",
    "start": "concurrently \"INTERNAL_BACKEND_PORT=4000 npm run start --workspace=server\" \"INTERNAL_BACKEND_PORT=4000 npm run start --workspace=client\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "concurrently": "^9.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.0.0"
  }
}